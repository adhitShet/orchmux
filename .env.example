# orchmux environment variables
# Copy this file to .env and fill in your values.
# orchmux.sh loads .env from this directory automatically. It also reads
# ~/.claude/hooks/.env if present (legacy location). Either is fine —
# values from either path take effect, and you can also export these
# variables in your shell environment directly.

# ── Telegram bot (optional — remove if not using the Telegram interface) ──────
# Create a bot via @BotFather and get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Network binding ────────────────────────────────────────────────────────────
# IP address orchmux server binds to.
# Defaults to Tailscale IP if detected, otherwise 127.0.0.1.
# Override here if you want a specific interface.
# ORCHMUX_BIND_HOST=127.0.0.1
